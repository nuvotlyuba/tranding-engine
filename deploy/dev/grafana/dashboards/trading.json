
{
  "title": "Trading Engine",
  "uid": "trading-engine-dev",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Requests per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(http_requests_total{service=\"trading-engine\"}[1m])",
          "legendFormat": "{{method}} {{path}} {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Request Duration (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{service=\"trading-engine\"}[1m]))",
          "legendFormat": "p99 {{path}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Event Bus — Events per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(eventbus_events_total{service=\"trading-engine\"}[1m])",
          "legendFormat": "{{topic}} {{subscriber}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Event Bus — Dropped Events",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(eventbus_events_dropped_total{service=\"trading-engine\"}) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "value": 0, "color": "green" },
            { "value": 1, "color": "red" }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Order Book — Active Levels",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "orderbook_levels{service=\"trading-engine\"}",
          "legendFormat": "{{symbol}} {{side}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Trades per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(trades_executed_total{service=\"trading-engine\"}[1m])",
          "legendFormat": "{{symbol}}"
        }
      ]
    }
  ]
}
